SESSION_SECRET=change-me-to-a-long-random-string

# OAuth (Google Cloud → APIs & Services → Credentials → OAuth 2.0 Client ID, type "Web application").
# Authorized redirect URI must match OAUTH_REDIRECT_URL exactly (e.g. http://localhost:8080/auth/callback).

# Local dev without Google: set true so the server starts; public pages work; leader Google sign-in is OFF.
# For /admin: set to false, fill GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET / OAUTH_REDIRECT_URL, restart.
DEV_SKIP_OAUTH=true

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
OAUTH_REDIRECT_URL=http://localhost:8080/auth/callback
ALLOWED_LEADER_EMAILS=you@gmail.com,other.leader@gmail.com
DATABASE_PATH=wardmission.db
COOKIE_SECURE=false
PUBLIC_BASE_URL=http://localhost:8080
