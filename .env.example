SESSION_SECRET=change-me-to-a-long-random-string

# Leader sign-in uses a signed session cookie (not OAuth). Defaults: idle 2 hours, max 24 hours.
# SESSION_IDLE_MINUTES=120
# SESSION_MAX_HOURS=24

# Database: omit DATABASE_URL to use SQLite in the backend working directory (default file
# wardmission.db). Set DATABASE_PATH to use a different file path.
#
# Production / optional local Postgres — adjust user/password/db name:
# DATABASE_URL=postgres://wardmission:wardmission@localhost:5432/wardmission?sslmode=disable
#
# Render injects DATABASE_URL automatically when you wire the Web Service to Render Postgres.

# Sign-in is email + password (bcrypt-hashed). Anyone can register an account at
# /admin; new accounts wait for an existing approved leader to approve them before they can
# sign in. The very first registration auto-approves so the site can bootstrap with no admin
# yet. Every approved account is a full admin (moderate experiences + edit every ward plan
# tab). There is no email allowlist — approval is the sole gate.

COOKIE_SECURE=false
PUBLIC_BASE_URL=https://albertsonwardplan.com

# Production (Render + custom domain): must match the browser URL exactly, no trailing slash.
# PUBLIC_BASE_URL=https://albertsonwardplan.com

# Outbound email (optional). When MAIL_ENABLED=true, leaders receive alerts for pending account
# requests and newly submitted mission experiences; forgot-password sends reset links.
# PUBLIC_BASE_URL must match the live site URL so links in emails work.
# Note: Render Free Web Services block outbound SMTP ports (25/465/587) — mail may require a paid tier or HTTP API provider.
# MAIL_ENABLED=false
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# MAIL_FROM=noreply@albertsonwardplan.com
# MAIL_FROM_NAME=Albertson Ward Mission Plan

# Shown in email subjects and HTML templates (default Albertson Ward).
# MAIL_SITE_LABEL=Albertson Ward

# Reset links expire after this many hours (default 24, max 720).
# PASSWORD_RESET_HOURS=24

# When running the Vite dev server (npm run dev on :5173) against this Go backend, set this to
# true so gorilla/csrf trusts the dev origin. Leave unset in production — the bundled SPA served
# directly from the Go server is same-origin and does not need this.
# DEV_TRUST_VITE=true

# When testing on a phone via `npm run dev:host`, add the LAN IP your phone hits as a trusted
# origin (gorilla/csrf rejects POSTs from origins it doesn't recognize). WSL2 cannot see the
# Windows-host LAN IP from inside the VM, so set it manually here. Bare host adds the dev
# port range; host:port pins one entry. Comma-separated for multiple.
# DEV_EXTRA_TRUSTED_ORIGINS=192.168.1.100,192.168.1.100:5173
