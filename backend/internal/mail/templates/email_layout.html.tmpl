{{ define "email_shell_start" }}
<!DOCTYPE html>
<html lang="en" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:o="urn:schemas-microsoft-com:office:office">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<meta http-equiv="x-ua-compatible" content="ie=edge">
<meta name="color-scheme" content="light">
<meta name="supported-color-schemes" content="light">
<title>{{ .EmailTitle }}</title>
<!--[if mso]>
<noscript>
  <xml>
    <o:OfficeDocumentSettings>
      <o:PixelsPerInch>96</o:PixelsPerInch>
    </o:OfficeDocumentSettings>
  </xml>
</noscript>
<![endif]-->
</head>
<body style="margin:0;padding:0;background-color:#f5efe2;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.55;color:#1b1812;-webkit-text-size-adjust:100%;">
{{ if .Preheader }}
<div style="display:none;max-height:0;overflow:hidden;mso-hide:all;font-size:1px;line-height:1px;color:#f5efe2;opacity:0;">
  {{ .Preheader }}&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;&nbsp;&zwnj;
</div>
{{ end }}
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="background-color:#f5efe2;background-image:linear-gradient(180deg,#f5efe2 0%,#ece4cf 100%);padding:40px 16px;">
  <tr>
    <td align="center" style="padding:0;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="max-width:560px;width:100%;background-color:#fffdf6;border-radius:16px;border:1px solid #e2dac6;box-shadow:0 10px 32px rgba(20,18,12,0.08);overflow:hidden;">
        <tr>
          <td style="padding:0;background-color:#1f3c63;background-image:linear-gradient(165deg,#2a5080 0%,#1f3c63 55%,#152c4a 100%);border-bottom:3px solid #b08745;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="padding:28px 32px 24px;">
                  <p style="margin:0 0 10px;font-family:Arial,Helvetica,sans-serif;font-size:11px;font-weight:700;letter-spacing:0.14em;text-transform:uppercase;color:#d4b87a;line-height:1.3;">
                    {{ .SiteLabel }} &middot; Ward Mission
                  </p>
                  <h1 style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:26px;font-weight:normal;line-height:1.25;color:#ffffff;">
                    {{ .Headline }}
                  </h1>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        <tr>
          <td style="padding:32px 32px 8px;font-family:Arial,Helvetica,sans-serif;font-size:16px;line-height:1.6;color:#1b1812;">
{{ end }}

{{ define "email_shell_end" }}
          </td>
        </tr>
        <tr>
          <td style="padding:8px 32px 28px;">
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
              <tr>
                <td style="border-top:1px solid #e2dac6;padding-top:20px;">
                  <p style="margin:0;font-family:Arial,Helvetica,sans-serif;font-size:13px;line-height:1.55;color:#8c8676;">
                    {{ .FooterNote }}
                  </p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
      <p style="margin:20px 0 0;font-family:Arial,Helvetica,sans-serif;font-size:12px;line-height:1.5;color:#8c8676;text-align:center;max-width:560px;">
        {{ .SiteLabel }} mission plan &middot; Local ward use only
      </p>
    </td>
  </tr>
</table>
</body>
</html>
{{ end }}

{{ define "email_cta_button" }}
<table role="presentation" cellpadding="0" cellspacing="0" border="0" style="margin:28px 0 8px;">
  <tr>
    <td align="left" style="border-radius:10px;background-color:#1f3c63;">
      <!--[if mso]>
      <v:roundrect xmlns:v="urn:schemas-microsoft-com:vml" xmlns:w="urn:schemas-microsoft-com:office:word" href="{{ .CTAURL }}" style="height:48px;v-text-anchor:middle;width:260px;" arcsize="12%" strokecolor="#8a6633" fillcolor="#1f3c63">
        <w:anchorlock/>
        <center style="color:#ffffff;font-family:Arial,sans-serif;font-size:16px;font-weight:bold;">{{ .CTALabel }}</center>
      </v:roundrect>
      <![endif]-->
      <!--[if !mso]><!-->
      <a href="{{ .CTAURL }}" target="_blank" style="display:inline-block;padding:14px 28px;font-family:Arial,Helvetica,sans-serif;font-size:16px;font-weight:700;line-height:1.25;color:#ffffff;text-decoration:none;border-radius:10px;background-color:#1f3c63;border-bottom:3px solid #8a6633;box-shadow:0 4px 14px rgba(31,60,99,0.28);">
        {{ .CTALabel }}
      </a>
      <!--<![endif]-->
    </td>
  </tr>
</table>
{{ end }}
