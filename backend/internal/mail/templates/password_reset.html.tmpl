{{ template "email_shell_start" . }}
            <p style="margin:0 0 20px;font-size:17px;line-height:1.6;color:#1b1812;">
              We received a request to reset the password for your leader account:
            </p>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 8px;">
              <tr>
                <td style="padding:16px 20px;background-color:#f5efe2;border:1px solid #e2dac6;border-left:4px solid #b08745;border-radius:10px;">
                  <p style="margin:0;font-size:15px;font-weight:700;color:#1f3c63;word-break:break-all;">{{ .LeaderEmail }}</p>
                </td>
              </tr>
            </table>
            {{ template "email_cta_button" . }}
            <p style="margin:20px 0 0;padding:14px 16px;background-color:#fff8e8;border:1px solid #e8d9a8;border-radius:8px;font-size:15px;line-height:1.5;color:#5b554a;">
              <strong style="color:#1b1812;">This link expires in {{ .ExpiryHours }} hours.</strong>
              For your security, request a new reset if it expires.
            </p>
            <p style="margin:16px 0 0;font-size:14px;line-height:1.5;color:#8c8676;">
              Or copy this link:<br>
              <a href="{{ .ResetLink }}" style="color:#1f3c63;word-break:break-all;">{{ .ResetLink }}</a>
            </p>
{{ template "email_shell_end" . }}
