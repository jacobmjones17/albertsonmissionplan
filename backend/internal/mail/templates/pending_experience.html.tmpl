<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>New mission experience</title>
</head>
<body style="margin:0;padding:0;background:#f4f4f2;font-family:Georgia,'Times New Roman',serif;font-size:19px;line-height:1.62;color:#1a1a1a;">
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background:#f4f4f2;padding:48px 20px;">
  <tr>
    <td align="center">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:720px;background:#ffffff;border-radius:14px;overflow:hidden;border:1px solid #dcdcd8;box-shadow:0 8px 28px rgba(0,0,0,0.06);">
        <tr>
          <td style="padding:44px 40px 28px;background:#2c5282;color:#ffffff;">
            <p style="margin:0;font-size:16px;letter-spacing:0.08em;text-transform:uppercase;opacity:0.92;">{{ .SiteLabel }}</p>
            <h1 style="margin:16px 0 0;font-size:36px;font-weight:normal;line-height:1.2;">New mission experience</h1>
          </td>
        </tr>
        <tr>
          <td style="padding:40px 44px 44px;">
            <p style="margin:0 0 8px;font-size:17px;color:#555;">Submitted by</p>
            <p style="margin:0 0 28px;font-size:21px;"><strong>{{ .AuthorLabel }}</strong></p>
            <p style="margin:0 0 12px;font-size:15px;color:#666;">Submission #{{ .SubmissionID }}</p>
            <p style="margin:0 0 14px;font-size:17px;color:#555;">Preview</p>
            <div style="margin:0 0 36px;padding:22px 24px;background:#f8f8f6;border-radius:10px;border:1px solid #eceae6;font-size:18px;line-height:1.58;color:#222;white-space:pre-wrap;">{{ .BodyPreview }}</div>
            <p style="margin:0;">
              <a href="{{ .ModerateURL }}" style="display:inline-block;background:#2c5282;color:#ffffff;text-decoration:none;padding:20px 36px;border-radius:10px;font-size:20px;font-weight:500;">Review moderation queue</a>
            </p>
            <hr style="border:none;border-top:2px solid #eee;margin:40px 0;">
            <p style="margin:0;font-size:16px;color:#666;line-height:1.55;">You received this email because you are an approved ward leader.</p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
</body>
</html>
