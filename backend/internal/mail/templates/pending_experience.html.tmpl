{{ template "email_shell_start" . }}
            <p style="margin:0 0 20px;font-size:17px;line-height:1.6;color:#1b1812;">
              A new mission experience was submitted and is waiting in your moderation queue.
            </p>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 12px;">
              <tr>
                <td style="padding:14px 16px;background-color:#f5efe2;border:1px solid #e2dac6;border-left:4px solid #b08745;border-radius:10px;">
                  <p style="margin:0 0 4px;font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#5b554a;">Submitted by</p>
                  <p style="margin:0;font-size:16px;font-weight:700;color:#1b1812;">{{ .AuthorLabel }}</p>
                </td>
              </tr>
            </table>
            <p style="margin:0 0 8px;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#5b554a;">Preview</p>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 8px;">
              <tr>
                <td style="padding:18px 20px;background-color:#ffffff;border:1px solid #e2dac6;border-left:4px solid #b08745;border-radius:10px;font-size:16px;line-height:1.58;color:#1b1812;white-space:pre-wrap;word-break:break-word;">{{ .BodyPreview }}</td>
              </tr>
            </table>
            {{ template "email_cta_button" . }}
            <p style="margin:16px 0 0;font-size:14px;line-height:1.5;color:#8c8676;">
              Or copy this link:<br>
              <a href="{{ .ModerateURL }}" style="color:#1f3c63;word-break:break-all;">{{ .ModerateURL }}</a>
            </p>
{{ template "email_shell_end" . }}
