{{ template "email_shell_start" . }}
            <p style="margin:0 0 20px;font-size:17px;line-height:1.6;color:#1b1812;">
              Someone requested access to ward leader tools (moderation, ward plan, and account approvals).
            </p>
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" style="margin:0 0 8px;">
              <tr>
                <td style="padding:18px 20px;background-color:#f5efe2;border:1px solid #e2dac6;border-left:4px solid #b08745;border-radius:10px;">
                  <p style="margin:0 0 6px;font-size:12px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;color:#5b554a;">Requester</p>
                  <p style="margin:0;font-family:Georgia,'Times New Roman',serif;font-size:20px;line-height:1.35;color:#0f0e0b;">{{ .RequesterDisplayName }}</p>
                  <p style="margin:8px 0 0;font-size:15px;line-height:1.45;color:#5b554a;">{{ .RequesterEmail }}</p>
                </td>
              </tr>
            </table>
            {{ template "email_cta_button" . }}
            <p style="margin:16px 0 0;font-size:14px;line-height:1.5;color:#8c8676;">
              Or copy this link:<br>
              <a href="{{ .ApprovalsURL }}" style="color:#1f3c63;word-break:break-all;">{{ .ApprovalsURL }}</a>
            </p>
{{ template "email_shell_end" . }}
